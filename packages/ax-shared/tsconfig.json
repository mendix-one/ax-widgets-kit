{
  "compilerOptions": {
    "target": "ES6",
    "lib": ["ESNext", "dom"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "declaration": true,
    "baseUrl": "./",
    "ignoreDeprecations": "6.0"
  },
  "include": ["src"]
}
